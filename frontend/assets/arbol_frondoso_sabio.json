            :host {
                display: block;
                padding: 10px 12px 12px 12px;
                margin-bottom: 16px;
                background-color: transparent;
                border-radius: 8px;
                font-family: 'Google Sans', Roboto, Arial, sans-serif;
                color: var(--gd-text-primary);
                transition: padding 0.2s ease-in-out, margin-bottom 0.2s ease-in-out; /* Smooth transition */
            }
            @keyframes gd-pulse-animation {
                0% { background-color: rgba(var(--gd-focus-ring-rgb), 0); }
                50% { background-color: rgba(var(--gd-focus-ring-rgb), 0.1); }
                100% { background-color: rgba(var(--gd-focus-ring-rgb), 0); }
            }
            .gd-pulse {
                animation: gd-pulse-animation 1s infinite;
            }
            :host(.gd-sidebar-collapsed) {
                /* Styles when sidebar is collapsed */
                padding: 8px; /* Reduced padding */
                margin-bottom: 8px; /* Reduced margin */
            }
            .gd-panel-header {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 12px;
                transition: margin-bottom 0.2s ease-in-out;
            }
            :host(.gd-sidebar-collapsed) .gd-panel-header {
                margin-bottom: 0; /* No margin for header when collapsed */
            }
            .gd-panel-header .title-area {
                display: flex;
                align-items: center;
                font-size: 14px;
                font-weight: 400;
                color: var(--gd-text-primary);
                transition: opacity 0.1s ease-in-out;
            }
            :host(.gd-sidebar-collapsed) .gd-panel-header .title-area span {
                display: none; /* Hide "Batch actions" text */
            }
            .gd-panel-header .title-area svg {
                 width: 18px; height: 18px;
                 margin-right: 10px;
                 fill: var(--gd-text-secondary);
            }
            :host(.gd-sidebar-collapsed) .gd-panel-header .title-area svg {
                margin-right: 0; /* No margin for icon when text is hidden */
            }
            
            .gd-switch {
                position: relative;
                display: inline-block;
                width: 36px; /* More compact switch */
                height: 20px;
            }
            .gd-switch input { 
                opacity: 0;
                width: 0;
                height: 0;
            }
            .gd-slider {
                position: absolute;
                cursor: pointer;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background-color: var(--gd-text-secondary); /* Grey when off, using theme variable */
                transition: .2s;
                border-radius: 20px; /* Fully rounded ends */
            }
            .gd-slider:before {
                position: absolute;
                content: "";
                height: 16px; 
                width: 16px;
                left: 2px; 
                bottom: 2px;
                background-color: white;
                transition: .2s;
                border-radius: 50%;
                box-shadow: 0 1px 2px rgba(0,0,0,0.2);
            }
            input:checked + .gd-slider {
                background-color: #0b57d0; 
            }
            input:focus + .gd-slider {
                box-shadow: 0 0 0 2px var(--gd-bg-primary), 0 0 0 4px var(--gd-focus-ring);
            }
            input:checked + .gd-slider:before {
                transform: translateX(16px); 
            }

            .gd-action-buttons {
                display: none; 
                flex-direction: column;
                gap: 10px;
                transition: opacity 0.1s ease-in-out, transform 0.2s ease-in-out;
                opacity: 1;
                transform: translateY(0);
            }
            :host(.gd-sidebar-collapsed) .gd-action-buttons {
                display: none !important; /* Ensure buttons are hidden */
                opacity: 0;
                transform: translateY(-10px); /* Optional: slight animation out */
            }
            .gd-action-buttons button {
                width: 100%;
                padding: 8px 12px; /* Adjusted padding for a less tall button */
                border: 1px solid transparent; /* Base border */
                border-radius: 8px; 
                text-align: center;
                font-family: 'Google Sans', Roboto, Arial, sans-serif;
                font-size: 14px;
                font-weight: 400; /* Reduced font weight for buttons */
                cursor: pointer;
                transition: background-color 0.15s ease-out, border-color 0.15s ease-out, color 0.15s ease-out;
            }
            .gd-action-buttons button#gd-select-all-btn {
                background-color: #0b57d0;
                color: white;
                border-color: #0b57d0;
            }
            .gd-action-buttons button#gd-select-all-btn:hover {
                 background-color: #0a4cb0; 
                 border-color: #0a4cb0;
            }
            .gd-action-buttons button#gd-delete-selected-btn {
                /* Styling for the "disabled" look based on screenshot */
                background-color: var(--gd-bg-primary); /* Match panel bg or slightly lighter variant */
                color: var(--gd-text-primary);
                border: 1px solid var(--gd-border-color);
            }
            .gd-action-buttons button#gd-delete-selected-btn:hover {
                 background-color: var(--gd-hover-bg); /* Use theme hover color */
                 border-color: var(--gd-text-secondary); /* Slightly more prominent border on hover */
            }
            /* TODO: Logic for enabling this button will change its style */
            .gd-action-buttons button#gd-delete-selected-btn.enabled {
                background-color: var(--gd-text-secondary); /* Example: Darker grey when enabled */
                color: var(--gd-bg-primary); /* Text color that contrasts with darker grey */
                border-color: var(--gd-text-secondary);
            }
            .gd-action-buttons button#gd-delete-selected-btn.enabled:hover {
                background-color: var(--gd-text-primary); /* Example: Even darker on hover */
                color: var(--gd-bg-primary);
                border-color: var(--gd-text-primary);
            }
