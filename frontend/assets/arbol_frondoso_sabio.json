        <span class="hljs-keyword">if</span> st.button(<span class="hljs-string">"👁️ Simular Fase en Pantalla"</span>):
            st.session_state[<span class="hljs-string">"estado_arbol_override"</span>] = fase_seleccionada
            st.rerun()

        <span class="hljs-keyword">if</span> <span class="hljs-string">"estado_arbol_override"</span> <span class="hljs-keyword">in</span> st.session_state:
            <span class="hljs-keyword">if</span> st.button(<span class="hljs-string">"🔄 Restablecer a Datos Reales"</span>):
