        <span class="hljs-string">"arbol_joven_creativo"</span>: (
            <span class="hljs-string">"🌳"</span>,
            <span class="hljs-string">"5. Árbol Joven Creativo (Creo y Transformo)"</span>,
            <span class="hljs-string">"Potencia la motivación y la expresión personal."</span>,
            <span class="hljs-string">"Desarrolla la creatividad y la resolución de problemas."</span>,
