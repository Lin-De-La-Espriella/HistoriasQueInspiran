    res_users = requests.get(<span class="hljs-string">f"<span class="hljs-subst">{API_URL}</span>/usuarios/"</span>, headers=headers)
    user_data = <span class="hljs-literal">None</span>
    <span class="hljs-keyword">if</span> res_users.status_code == <span class="hljs-number">200</span>:
        user_data = <span class="hljs-built_in">next</span>((u <span class="hljs-keyword">for</span> u <span class="hljs-keyword">in</span> res_users.json() <span class="hljs-keyword">if</span> u[<span class="hljs-string">"id"</span>] == usuario_id), <span class="hljs-literal">None</span>)

    pasaporte = user_data.get(<span class="hljs-string">"pasaporte"</span>, {}) <span class="hljs-keyword">if</span> user_data <span class="hljs-keyword">else</span> {}
