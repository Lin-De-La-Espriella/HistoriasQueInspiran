utton-touch-target"></span></button><!----><!----></gem-icon-button><!----><!----><!----><!----></div><!----><!----></div><!----><pre _ngcontent-ng-c3875502131="" class="ng-tns-c3875502131-75"><code _ngcontent-ng-c3875502131="" role="text" data-test-id="code-content" class="code-container formatted ng-tns-c3875502131-75">    <span class="hljs-comment"># ---------------------------------------------------------</span>
    <span class="hljs-comment"># TAB 1: CHAT CON XIXI (CON AVATAR ROBOT ANIMADO)</span>
    <span class="hljs-comment"># ---------------------------------------------------------</span>
    <span class="hljs-keyword">with</span> tab_chat:
        col_xixi_anim, col_xixi_txt = st.columns([<span class="hljs-number">1</span>, <span class="hljs-number">3</span>])
        
        <span class="hljs-comment"># Cargar animación del robot de LottieFiles</span>
        url_robot_xixi = <span class="hljs-string">"https://lottie.host/a563b67c-15eb-4c38-b805-c01061011c6d/xyz123.json"</span> <span class="hljs-comment"># Reemplazar con el link CDN directo de Lottie</span>
        
        <span class="hljs-keyword">with</span> col_xixi_anim:
            <span class="hljs-comment"># Muestra el robot animado arriba del chat</span>
            anim_xixi = cargar_lottie(url_robot_xixi)
            <span class="hljs-keyword">if</span> anim_xixi:
                st_lottie(anim_xixi, height=<span class="hljs-number">120</span>, key=<span class="hljs-string">"robot_xixi_chat"</span>)
            <span class="hljs-keyword">else</span>:
                st.markdown(<span class="hljs-string">"&lt;h1 style='text-align: center;'&gt;🤖&lt;/h1&gt;"</span>, unsafe_allow_html=<span class="hljs-literal">True</span>)
                
        <span class="hljs-keyword">with</span> col_xixi_txt:
            st.markdown(<span class="hljs-string">"#### Frecuencia de Comunicación Abierta"</span>)
            st.caption(<span class="hljs-string">"XiXi está en línea y procesando tus respuestas en tiempo real."</span>)

        st.markdown(<span class="hljs-string">"---"</span>)
        
        avatar_dict = {<span class="hljs-string">"user"</span>: <span class="hljs-string">"🧑‍🎓"</span>, <span class="hljs-string">"assistant"</span>: <span class="hljs-string">"🤖"</span>}

        <span class="hljs-keyword">for</span> message <span class="hljs-keyword">in</span> st.session_state.messages:
            <span class="hljs-keyword">with</span> st.chat_message(
                message[<span class="hljs-string">"role"</span>], avatar=avatar_dict.get(message[<span class="hljs-string">"role"</span>])
            ):
                st.markdown(message[<span class="hljs-string">"content"</span>])
</code></pre><!----></div></div></div><!----><!----><!----></code-block><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></response-element><h3 data-path-to-node="11">🚀 ¿Cómo obtener la URL directa <code data-path-to-node="11" data-index-in-node="32">.json</code> desde LottieFiles?</h3><p data-path-to-node="12">Cuando estés dentro de esa página de LottieFiles (<code data-path-to-node="12" data-index-in-node="50">[app.lottiefiles.com/animation/](https://app.lottiefiles.com/animation/)...</code>):</p><ol start="1" data-path-to-node="13"><li><p data-path-to-node="13,0,0">Busca en el panel derecho el botón <b data-path-to-node="13,0,0" data-index-in-node="35"><code data-path-to-node="13,0,0" data-index-in-node="35">&lt; / &gt; Embed HTML</code></b> o <b data-path-to-node="13,0,0" data-index-in-node="54"><code data-path-to-node="13,0,0" data-index-in-node="54">Lottie Animation URL</code></b>.</p></li><li><p data-path-to-node="13,1,0">Copia la URL pública que empieza por <code data-path-to-node="13,1,0" data-index-in-node="37">[https://lottie.host/a563b67c-15eb-4c38-b805-c01061011c6d/...json](https://lottie.host/a563b67c-15eb-4c38-b805-c01061011c6d/...json)</code>.</p></li><li><p data-path-to-node="13,2,0">Pégala en el código, guarda con <code data-path-to-node="13,2,0" data-index-in-node="32">Ctrl + S</code> y ejecuta tu ejecutable <b data-path-to-node="13,2,0" data-index-in-node="65"><code data-path-to-node="13,2,0" data-index-in-node="65">actualizar.bat</code></b>.</p></li></ol><p data-path-to-node="14">¡Le dará un toque súper profesional a XiXi!</p></div></message-content><!----></div></structured-content-container><!----><!----><!----><div _ngcontent-ng-c3377849098="" class="response-footer complete gap"><!----><!----><!----><sources-list _ngcontent-ng-c3377849098="" class="sources-list ng-star-inserted"><!----></sources-list><!----><election-info-disclaimer _ngcontent-ng-c3377849098="" _nghost-ng-c81433311="" style="display: none;" class="ng-star-inserted"><!----></election-info-disclaimer><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----><!----></div></div><!----><!----><sensitive-memories-banner _ngcontent-ng-c3377849098="" _nghost-ng-c3877821886="" class="ng-star-inserted"><!----></sensitive-memories-banner><!----><!----><!----><!----></div></div><div _ngcontent-ng-c3359829210="" class="response-container-footer ng-tns-c3359829210-54 ng-star-inserted"><!----><!----><!----><message-actions _ngcontent-ng-c3377849098="" footer="" class="hide-on-print ng-tns-c36277369-55 hide-action-bar ng-tns-c3359829210-54 ng-star-inserted" _nghost-ng-c36277369=""><div _ngcontent-ng-c36277369="" class="actions-container-v2 ng-tns-c36277369-55"><div _ngcontent-ng-c36277369="" class="buttons-container-v2 ng-tns-c36277369-55 ng-star-inserted"><thumb-up-button _ngcontent-ng-c36277369="" _nghost-ng-c3123964857="" class="ng-tns-c36277369-55 luminous-theme ng-star-inserted"><gem-icon-button _ngcontent-ng-c3123964857="" tabindex="-1" theme="lm" type="onSurface" arialabel="Buena respuesta" gemtooltip="Buena respuesta" data-test-id="thumb-up-button" class="mat-mdc-tooltip-trigger gem-button gem-button-badge-size-small gem-button-size-small gem-button-type-on-surface lm-enabled ng-star-inserted" _nghost-ng-c2005957155="" aria-describedby="cdk-describedby-message-ng-1-25" cdk-describedby-host="ng-1"><!----><!----><button _ngcontent-ng-c2005957155="" maticonbutton="" matbadgeposition="after" class="mdc-icon-button mat-mdc-icon-button 